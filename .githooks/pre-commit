#!/usr/bin/env bash
# Pre-commit hook: format, lint, and test before allowing a commit.
# Bypass for emergencies with `SKIP_HOOK=1 git commit ...`.

set -euo pipefail

if [[ "${SKIP_HOOK:-0}" == "1" ]]; then
    echo "pre-commit: skipped (SKIP_HOOK=1)"
    exit 0
fi

# Skip if no Rust-relevant files are staged.
if ! git diff --cached --name-only --diff-filter=ACMR \
    | grep -qE '\.(rs|toml|lock)$'; then
    exit 0
fi

run() {
    echo "pre-commit: $*"
    "$@"
}

run cargo fmt --all -- --check
run cargo clippy --all-targets --workspace -- -D warnings
run cargo test --workspace --quiet
